{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "savel",
	"version": "0.1.0",
	"identifier": "com.lauriahlfors.savel",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "Sävel",
				"width": 800,
				"height": 600,
				"decorations": true,
				"backgroundColor": "#0a0a0a"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
